# Copy to .env (same directory as docker-compose.yml) and fill in real values.
# Never commit the real .env file.

# Absolute path on the HOST machine to your Minecraft server's data directory —
# the one that contains a "logs/" subfolder. Points at whatever the itzg
# container's own data volume already is.
MC_DATA_DIR=/path/to/your/minecraft/data

# Domain this app will be served on (Caddy issues a Let's Encrypt cert for it
# automatically). Must have a DNS A/AAAA record pointing at this host.
DOMAIN=mc-logs.example.com

# Generate with: pnpm --filter @open-log/backend hash-password <your-password>
AUTH_PASSWORD_HASH=

# Random 32+ character string used to encrypt session cookies
SESSION_SECRET=

# 0 unless your Minecraft server's local time isn't UTC
SERVER_TZ_OFFSET_HOURS=0

# See the comment in docker-compose.yml — leave "true" unless you've confirmed
# native file-change events work reliably on your host.
WATCH_USE_POLLING=true

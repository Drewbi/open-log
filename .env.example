# Absolute path on the HOST machine to the minecraft server's /data directory
MC_DATA_DIR=/path/to/your/minecraft/data

# Generate with: pnpm --filter @open-log/backend hash-password <your-password>
AUTH_PASSWORD_HASH=

# Random 32+ character string used to encrypt session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# 0 unless your Minecraft server's local time isn't UTC
SERVER_TZ_OFFSET_HOURS=0

# See the comment in docker-compose.yml — leave "true" unless you've confirmed
# native file-change events work reliably on your host.
WATCH_USE_POLLING=true

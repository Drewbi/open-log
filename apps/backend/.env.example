# Copy to .env and fill in real values. Never commit the real .env file.

# Path to the Minecraft server's logs/ folder (contains latest.log + rotated .log.gz files)
MC_LOGS_DIR=../../example-data/logs

# Where the SQLite database is stored
DB_PATH=./data/open-log.db

PORT=4000

# Shown after "OPEN LOG //" in the tab title, header, and login screen, e.g. "My SMP". Leave blank to show "TIMELINE".
SERVER_NAME=

# Fixed hour offset to convert the log's local wall-clock time to UTC (0 = treat log times as UTC)
SERVER_TZ_OFFSET_HOURS=0

# Set to true if file change events aren't detected reliably (e.g. some Docker Desktop bind mounts)
WATCH_USE_POLLING=false

# Generate with: pnpm hash-password <your-password>
AUTH_PASSWORD_HASH=

# Random 32+ character string used to encrypt session cookies
SESSION_SECRET=
